NODE_ENV=development
PORT=5000

# MongoDB
MONGODB_URI=mongodb://localhost:27017/golf_charity

# Auth
JWT_SECRET=replace_me_with_strong_secret
JWT_EXPIRES_IN=7d

# Cloudinary (winner proof uploads)
CLOUDINARY_CLOUD_NAME=replace_me
CLOUDINARY_API_KEY=replace_me
CLOUDINARY_API_SECRET=replace_me
# Use an unsigned upload preset if you prefer; signed uploads still work if you provide the preset.
CLOUDINARY_UPLOAD_PRESET=replace_me

# Stripe (for subscription flow later)
STRIPE_SECRET_KEY=replace_me
STRIPE_WEBHOOK_SECRET=replace_me

# Email notifications (SMTP)
SMTP_HOST=replace_me
SMTP_PORT=587
SMTP_USER=replace_me
SMTP_PASS=replace_me
SMTP_FROM_EMAIL=your-email@example.com

# Admin seeding (creates admin users at startup)
# Comma-separated emails to seed as admins
ADMIN_SEED_EMAILS=admin@example.com
# Either one password for all seeded admins or set per-email in a JSON string.
ADMIN_SEED_PASSWORD=replace_me

